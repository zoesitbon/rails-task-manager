<h1>New Task</h1>

<%= form_with model: @task, local: true do |form| %>
  <div>
    <%= form.label :title %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :details %>
    <%= form.text_area :details %>
  </div>

  <div>
    <%= form.label :completed, "Task completed?" %>
    <%= form.check_box :completed %>
  </div>

  <%= form.submit "Create Task" %>
  <%= link_to "Back to list", "/tasks" %>
<% end %>
