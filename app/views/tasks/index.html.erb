<h1>My Tasks</h1>

<% @tasks.each do |task| %>
  <div>
    <h2><%= task.title %></h2>
    <input type="checkbox" <%= "checked" if task.completed %> disabled>
    <%= link_to task.title, task_path(task.id)%>
  </div>
  </div>
  <%= link_to "Delete", destroy_task_path(task), data: { turbo_method: :delete, turbo_confirm: "Are you sure?"}%>
<% end %>
<%= link_to "Add a new task", tasks_new_path %>
