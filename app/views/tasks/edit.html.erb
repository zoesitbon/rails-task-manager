<h1> Update the task </h1>

<%= form_with model: @task, local: true do |form| %>
<div>
  <%= form.label :title %>
  <%= form.text_field :title %>
</div>
<div>
  <%= form.label :details %>
  <%= form.text_field :details %>
</div>
<div>
  <%= form.label :completed, "Task completed?" %>
  <%= form.check_box :completed %>
</div>
  <%= form.submit "Update Task" %>
  <% end %>
  <%= link_to "Back to list", tasks_path %>
